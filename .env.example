# MA/PM AR Inspector — Configuration
# Copy this file to .env and adjust values as needed.
# All settings have sensible defaults; you only need to change what you want.

# ── Server ─────────────────────────────────────────────────────────────────
PORT=3001

# ── Admin login ─────────────────────────────────────────────────────────────
ADMIN_USER=docadmin
ADMIN_PASS=admin1234

# ── Database ─────────────────────────────────────────────────────────────────
# Relative path → resolved from the project root.
# Docker: use an absolute path that maps to a named volume, e.g. /app/data/mapm.db
DB_PATH=./mapm.db

# ── Machine defaults ─────────────────────────────────────────────────────────
# Default PM trigger threshold (hours) when creating a new machine.
PM_TRIGGER_HOURS=500

# ── Demo data ────────────────────────────────────────────────────────────────
# Set to false to skip seeding MCH-001/002/003 on first run.
DEMO_SEED=true
