# MA/PM AR Inspector — Docker deployment config
# Copy to .env (same folder as docker-compose.yml) and edit before first run.
# DB_PATH is fixed by docker-compose.yml; all other settings are optional.

PORT=3001
ADMIN_USER=docadmin
ADMIN_PASS=admin1234
PM_TRIGGER_HOURS=500
DEMO_SEED=true

# Host IP of the Linux server — added to the self-signed cert SAN so
# browsers on the LAN trust HTTPS and allow camera access.
# Set this to the IP workers will type into their phones.
SERVER_IP=192.168.1.100
